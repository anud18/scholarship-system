{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "RustFS Health (blackbox probe of the S3 API port — RustFS has no MinIO-style /minio/v2/metrics endpoints)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "1 = the S3 endpoint on the DB-VM answers the Alloy blackbox HTTP probe. Feeds the StorageDown alert.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 1, "text": "DOWN" },
                "1": { "color": "green", "index": 0, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "probe_success{environment=\"$environment\", vm=\"db-vm\", job=\"storage\"}",
          "legendFormat": "storage",
          "refId": "A"
        }
      ],
      "title": "Storage Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "HTTP status the probe received. RustFS answers 200 on /health; a 4xx here means a MinIO server is still answering (pre-cutover or rollback state).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 200 },
              { "color": "yellow", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "probe_http_status_code{environment=\"$environment\", vm=\"db-vm\", job=\"storage\"}",
          "legendFormat": "HTTP status",
          "refId": "A"
        }
      ],
      "title": "Probe HTTP Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "Availability over the dashboard window (mean of probe_success).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "avg_over_time(probe_success{environment=\"$environment\", vm=\"db-vm\", job=\"storage\"}[$__range])",
          "legendFormat": "availability",
          "refId": "A"
        }
      ],
      "title": "Availability (window)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "End-to-end HTTP probe latency against the S3 port.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "probe_duration_seconds{environment=\"$environment\", vm=\"db-vm\", job=\"storage\"}",
          "legendFormat": "probe duration",
          "refId": "A"
        }
      ],
      "title": "Probe Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "Up/down history of the storage endpoint. Gaps mean the DB-VM Alloy itself stopped pushing (check the Alloy container), not necessarily a storage outage.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "id": 5,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "probe_success{environment=\"$environment\", vm=\"db-vm\", job=\"storage\"}",
          "legendFormat": "probe_success",
          "refId": "A"
        }
      ],
      "title": "Storage Uptime History",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 101,
      "panels": [],
      "title": "DB-VM Disk (storage data lives on the DB-VM filesystem — node-exporter view)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "description": "Filesystem usage on the DB-VM hosting the RustFS data directory. DiskSpaceLow (>80%) / DiskSpaceCritical (>90%) alerts fire from these series.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "(1 - (node_filesystem_avail_bytes{environment=\"$environment\", vm=\"db-vm\", fstype!~\"tmpfs|fuse.lxcfs|squashfs|vfat\"} / node_filesystem_size_bytes{environment=\"$environment\", vm=\"db-vm\", fstype!~\"tmpfs|fuse.lxcfs|squashfs|vfat\"})) * 100",
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ],
      "title": "DB-VM Filesystem Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["database", "rustfs", "storage"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "staging",
          "value": "staging"
        },
        "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
        "definition": "label_values(up, environment)",
        "description": "Select environment",
        "hide": 0,
        "includeAll": false,
        "label": "Environment",
        "multi": false,
        "name": "environment",
        "options": [],
        "query": {
          "query": "label_values(up, environment)",
          "refId": "StandardVariableQuery"
        },
        "queryValue": "",
        "refresh": 1,
        "regex": "/^(?!monitoring).*$/",
        "skipUrlSync": false,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Object Storage (RustFS) Monitoring",
  "uid": "storage-monitoring",
  "version": 1,
  "weekStart": ""
}
